#!/usr/bin/env bash
set -euo pipefail

# tm - Abstract Task Manager CLI
# Routes commands to the configured backend (bd by default).
# Part of the Hyperpowers plugin system.

TM_VERSION="0.1.0"

trim() {
  local value="${1:-}"
  value="${value#"${value%%[![:space:]]*}"}"
  value="${value%"${value##*[![:space:]]}"}"
  printf '%s\n' "$value"
}

# ── Repo root detection ──────────────────────────────────────────────────────

find_repo_root() {
  if [[ -n "${TM_REPO_ROOT:-}" && -d "${TM_REPO_ROOT}/.beads" ]]; then
    echo "$TM_REPO_ROOT"
    return
  fi

  local root
  root="$(find_repo_root_from "$PWD")"
  if [[ -n "$root" ]]; then
    echo "$root"
    return
  fi

  local script_dir
  script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  root="$(find_repo_root_from "$script_dir")"
  if [[ -n "$root" ]]; then
    echo "$root"
  fi
}

find_repo_root_from() {
  local dir="$1"
  while [[ -n "$dir" && "$dir" != "/" ]]; do
    if [[ -d "$dir/.beads" ]]; then
      echo "$dir"
      return
    fi
    dir="$(dirname "$dir")"
  done
}

# ── Backend detection ────────────────────────────────────────────────────────

detect_backend() {
  # Priority: env var > config file > default
  if [[ ${TM_BACKEND+x} ]]; then
    local env_backend
    env_backend="$(trim "${TM_BACKEND}")"
    if [[ -n "$env_backend" ]]; then
      echo "$env_backend"
      return
    fi
  fi

  # Check .beads/config.yaml for tm.backend (flat YAML, no external deps)
  local root config
  root="$(find_repo_root)"
  if [[ -n "$root" ]]; then
    config="$root/.beads/config.yaml"
    if [[ -f "$config" && -r "$config" ]]; then
      local val
      val=$(grep '^tm\.backend:' "$config" 2>/dev/null | awk '{gsub(/["'"'"']/, "", $2); print $2}' || true)
      val="$(trim "$val")"
      if [[ -n "$val" ]]; then
        echo "$val"
        return
      fi
    fi
  fi

  echo "bd"
}

load_linear_config_value() {
  local env_name="$1"
  local config_key="$2"
  local backend_cmd="${3:-}"

  if [[ ${!env_name+x} ]]; then
    local env_val
    env_val="$(trim "${!env_name}")"
    printf '%s\n' "$env_val"
    return
  fi

  local root config config_val
  root="$(find_repo_root)"
  if [[ -n "$root" ]]; then
    config="$root/.beads/config.yaml"
    if [[ -f "$config" && -r "$config" ]]; then
      config_val="$(awk -v key="$config_key" '
        function trim_spaces(str) {
          sub(/^[[:space:]]+/, "", str)
          sub(/[[:space:]]+$/, "", str)
          return str
        }

        function strip_inline_comment(str,    i, ch, prev, in_single, in_double, out) {
          in_single = 0
          in_double = 0
          out = ""

          for (i = 1; i <= length(str); i++) {
            ch = substr(str, i, 1)
            prev = (i > 1) ? substr(str, i - 1, 1) : ""

            if (ch == "\"" && !in_single) {
              in_double = !in_double
              out = out ch
              continue
            }

            if (ch == "\047" && !in_double) {
              in_single = !in_single
              out = out ch
              continue
            }

            if (ch == "#" && !in_single && !in_double && (i == 1 || prev ~ /[[:space:]]/)) {
              break
            }

            out = out ch
          }

          return trim_spaces(out)
        }

        index($0, key ":") == 1 {
          value = $0
          sub(/^[^:]*:[[:space:]]*/, "", value)
          value = strip_inline_comment(value)
          gsub(/^[\"\047]|[\"\047]$/, "", value)
          print value
          exit
        }
      ' "$config" 2>/dev/null || true)"
      config_val="$(trim "$config_val")"
      if [[ -n "$config_val" && "$config_val" != *"(not set)" ]]; then
        printf '%s\n' "$config_val"
        return
      fi
    fi
  fi

  # Compatibility fallback: if backend config stores integration values outside
  # .beads/config.yaml, read via backend config when available.
  if [[ -n "$backend_cmd" && "$backend_cmd" != "linear" ]] && command -v "$backend_cmd" >/dev/null 2>&1; then
    config_val="$($backend_cmd config get "$config_key" 2>/dev/null || true)"
    config_val="$(trim "$config_val")"
    if [[ -n "$config_val" && "$config_val" != *"(not set)" ]]; then
      printf '%s\n' "$config_val"
      return
    fi
  fi

  printf '\n'
}

linear_sync_configured() {
  local backend_cmd="${1:-bd}"
  local api_key
  api_key="$(load_linear_config_value LINEAR_API_KEY linear.api-key "$backend_cmd")"
  [[ -n "$api_key" ]]
}

# ── Validation ───────────────────────────────────────────────────────────────

validate_backend() {
  local backend="$1"
  case "$backend" in
    bd|br|linear) ;;
    *)
      echo "tm: unknown backend '$backend'. Valid backends: bd, br, linear" >&2
      exit 1
      ;;
  esac
}

# ── Help / Version ───────────────────────────────────────────────────────────

show_help() {
  local backend
  backend=$(detect_backend)
  cat <<EOF
tm - Abstract Task Manager CLI (v${TM_VERSION})

Usage: tm <command> [args...]

Routes all commands to the configured backend.
Currently configured backend: ${backend}

Backend detection (highest priority first):
  1. TM_BACKEND environment variable
  2. tm.backend in .beads/config.yaml
  3. Default: bd

Available backends:
  bd      Local beads task manager (default)
  br      Local beads_rust task manager
  linear  Linear.app integration (not yet implemented)

Examples:
  tm ready              Show tasks ready to work on
  tm show bd-3          Show task details
  tm create "Title"     Create a new task
  tm close bd-3         Close a task

All arguments are passed through to the backend unchanged.
EOF
}

show_version() {
  local backend
  backend=$(detect_backend)
  echo "tm ${TM_VERSION} (backend: ${backend})"
}

# ── Main ─────────────────────────────────────────────────────────────────────

main() {
  # Handle tm-specific flags before routing
  if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
    show_help
    exit 0
  fi

  if [[ "${1:-}" == "--version" || "${1:-}" == "-v" ]]; then
    show_version
    exit 0
  fi

  local backend
  backend=$(detect_backend)
  validate_backend "$backend"

  case "$backend" in
    bd|br)
      local backend_cmd
      backend_cmd="$backend"
      if ! command -v "$backend_cmd" >/dev/null 2>&1; then
        if [[ "$backend_cmd" == "bd" ]]; then
          echo "tm: bd not found in PATH. Install beads first: https://github.com/Dicklesworthstone/beads_viewer" >&2
        else
          echo "tm: br not found in PATH. Install beads_rust first: https://github.com/Dicklesworthstone/beads_rust" >&2
        fi
        exit 1
      fi
      local repo_root
      repo_root="$(find_repo_root)"
      if [[ -n "$repo_root" ]]; then
        cd "$repo_root"
      fi
      # Intercept sync: run backend-local sync first, then supported follow-on sync.
      if [[ "${1:-}" == "sync" ]]; then
        if [[ "${2:-}" == "--help" || "${2:-}" == "-h" || "${2:-}" == "--version" || "${2:-}" == "-v" ]]; then
          exec "$backend_cmd" "$@"
        fi
        local sync_exit=0
        if [[ "$backend_cmd" == "br" ]]; then
          "$backend_cmd" sync --flush-only "${@:2}" || sync_exit=$?
        else
          "$backend_cmd" sync "${@:2}" || sync_exit=$?
        fi

        # Only run follow-on sync if local sync succeeded
        if [[ "$sync_exit" -ne 0 ]]; then
          echo "tm: ${backend_cmd} sync failed (exit $sync_exit), skipping follow-on sync" >&2
          exit "$sync_exit"
        fi

        if [[ "$backend_cmd" == "br" ]]; then
          if linear_sync_configured "$backend_cmd"; then
            echo "tm: follow-on Linear sync is not supported for backend 'br'; local sync completed and follow-on sync was skipped" >&2
          fi
          exit 0
        fi

        local script_dir source_path
        source_path="${BASH_SOURCE[0]}"
        # Resolve symlinks (e.g., npm bin installs)
        while [[ -L "$source_path" ]]; do
          script_dir="$(cd "$(dirname "$source_path")" && pwd)"
          source_path="$(readlink "$source_path")"
          [[ "$source_path" != /* ]] && source_path="$script_dir/$source_path"
        done
        script_dir="$(cd "$(dirname "$source_path")" && pwd)"
        if ! command -v node >/dev/null 2>&1; then
          if linear_sync_configured "$backend_cmd"; then
            echo "tm: Linear sync is configured but Node.js is unavailable." >&2
            exit 1
          fi
          exit 0
        fi
        if [[ ! -f "$script_dir/tm-linear-sync.js" ]]; then
          if linear_sync_configured "$backend_cmd"; then
            echo "tm: Linear sync is configured but tm-linear-sync.js is missing." >&2
            exit 1
          fi
          exit 0
        fi
        local linear_exit=0
        TM_REPO_ROOT="${repo_root:-$PWD}" node "$script_dir/tm-linear-sync.js" || linear_exit=$?
        if [[ "$linear_exit" -ne 0 ]]; then
          echo "tm: Linear sync failed with exit code $linear_exit" >&2
        fi
        exit "$linear_exit"
      fi
      exec "$backend_cmd" "$@"
      ;;
    linear)
      echo "tm: Linear backend not yet implemented. Use TM_BACKEND=bd (default) for now." >&2
      exit 1
      ;;
  esac
}

main "$@"
