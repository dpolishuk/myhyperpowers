#!/usr/bin/env bash
set -euo pipefail

# tm - Abstract Task Manager CLI
# Routes commands to the configured backend (bd by default).
# Part of the XPowers plugin system.

TM_VERSION="0.1.0"

SCRIPT_SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SCRIPT_SOURCE" ]]; do
  SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_SOURCE")" && pwd)"
  SCRIPT_SOURCE="$(readlink "$SCRIPT_SOURCE")"
  [[ "$SCRIPT_SOURCE" != /* ]] && SCRIPT_SOURCE="$SCRIPT_DIR/$SCRIPT_SOURCE"
done
TM_SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_SOURCE")" && pwd)"

# shellcheck source=/dev/null
source "$TM_SCRIPT_DIR/tm-backends.sh"

trim() {
  local value="${1:-}"
  value="${value#"${value%%[![:space:]]*}"}"
  value="${value%"${value##*[![:space:]]}"}"
  printf '%s\n' "$value"
}

# ── Repo root detection ──────────────────────────────────────────────────────

find_repo_root() {
  if [[ -n "${TM_REPO_ROOT:-}" && -d "${TM_REPO_ROOT}/.beads" ]]; then
    echo "$TM_REPO_ROOT"
    return
  fi

  local root
  root="$(find_repo_root_from "$PWD")"
  if [[ -n "$root" ]]; then
    echo "$root"
    return
  fi

  root="$(find_repo_root_from "$TM_SCRIPT_DIR")"
  if [[ -n "$root" ]]; then
    echo "$root"
  fi
}

find_repo_root_from() {
  local dir="$1"
  while [[ -n "$dir" && "$dir" != "/" ]]; do
    if [[ -d "$dir/.beads" ]]; then
      echo "$dir"
      return
    fi
    dir="$(dirname "$dir")"
  done
}

# ── Backend detection ────────────────────────────────────────────────────────

detect_backend() {
  # Priority: env var > config file > default
  if [[ ${TM_BACKEND+x} ]]; then
    local env_backend
    env_backend="$(trim "${TM_BACKEND}")"
    if [[ -n "$env_backend" ]]; then
      echo "$env_backend"
      return
    fi
  fi

  # Check .beads/config.yaml for tm.backend (flat YAML, no external deps)
  local root config
  root="$(find_repo_root)"
  if [[ -n "$root" ]]; then
    config="$root/.beads/config.yaml"
    if [[ -f "$config" && -r "$config" ]]; then
      local val
      val=$(grep '^tm\.backend:' "$config" 2>/dev/null | awk '{gsub(/["'"'"']/, "", $2); print $2}' || true)
      val="$(trim "$val")"
      if [[ -n "$val" ]]; then
        echo "$val"
        return
      fi
    fi
  fi

  echo "bd"
}

load_linear_config_value() {
  local env_name="$1"
  local config_key="$2"
  local backend_cmd="${3:-}"

  if [[ ${!env_name+x} ]]; then
    local env_val
    env_val="$(trim "${!env_name}")"
    printf '%s\n' "$env_val"
    return
  fi

  local root config config_val
  root="$(find_repo_root)"
  if [[ -n "$root" ]]; then
    config="$root/.beads/config.yaml"
    if [[ -f "$config" && -r "$config" ]]; then
      config_val="$(awk -v key="$config_key" '
        function trim_spaces(str) {
          sub(/^[[:space:]]+/, "", str)
          sub(/[[:space:]]+$/, "", str)
          return str
        }

        function strip_inline_comment(str,    i, ch, prev, in_single, in_double, out) {
          in_single = 0
          in_double = 0
          out = ""

          for (i = 1; i <= length(str); i++) {
            ch = substr(str, i, 1)
            prev = (i > 1) ? substr(str, i - 1, 1) : ""

            if (ch == "\"" && !in_single) {
              in_double = !in_double
              out = out ch
              continue
            }

            if (ch == "\047" && !in_double) {
              in_single = !in_single
              out = out ch
              continue
            }

            if (ch == "#" && !in_single && !in_double && (i == 1 || prev ~ /[[:space:]]/)) {
              break
            }

            out = out ch
          }

          return trim_spaces(out)
        }

        index($0, key ":") == 1 {
          value = $0
          sub(/^[^:]*:[[:space:]]*/, "", value)
          value = strip_inline_comment(value)
          gsub(/^[\"\047]|[\"\047]$/, "", value)
          print value
          exit
        }
      ' "$config" 2>/dev/null || true)"
      config_val="$(trim "$config_val")"
      if [[ -n "$config_val" && "$config_val" != *"(not set)" ]]; then
        printf '%s\n' "$config_val"
        return
      fi
      # If the key line exists in the file but the value is empty, honor
      # the explicit empty — do not fall through to backend config.
      if grep -q "^${config_key//./\\.}:" "$config" 2>/dev/null; then
        return
      fi
    fi
  fi

  # Compatibility fallback: if backend config stores integration values outside
  # .beads/config.yaml, read via backend config when available.
  if [[ -n "$backend_cmd" && "$backend_cmd" != "linear" ]] && command -v "$backend_cmd" >/dev/null 2>&1; then
    config_val="$($backend_cmd config get "$config_key" 2>/dev/null || true)"
    config_val="$(trim "$config_val")"
    if [[ -n "$config_val" && "$config_val" != *"(not set)" && "$config_val" != *[[:space:]]* ]] && is_valid_linear_fallback_value "$config_key" "$config_val"; then
      printf '%s\n' "$config_val"
      return
    fi
  fi

  printf '\n'
}

is_valid_linear_fallback_value() {
  local config_key="$1"
  local config_val="$2"
  case "$config_key" in
    linear.api-key)
      [[ "$config_val" == lin_* ]]
      ;;
    linear.team-key)
      [[ "$config_val" =~ ^[A-Z0-9_-]+$ ]]
      ;;
    *)
      [[ -n "$config_val" ]]
      ;;
  esac
}

linear_sync_configured() {
  local backend_cmd="${1:-bd}"
  local api_key
  local team_key
  api_key="$(load_linear_config_value LINEAR_API_KEY linear.api-key "$backend_cmd")"
  team_key="$(load_linear_config_value LINEAR_TEAM_KEY linear.team-key "$backend_cmd")"
  [[ -n "$api_key" && -n "$team_key" ]]
}

# ── Validation ───────────────────────────────────────────────────────────────

validate_backend() {
  local backend="$1"
  if ! tm_backend_is_supported "$backend"; then
    echo "tm: unknown backend '$backend'. Valid backends: $(tm_backend_valid_list)" >&2
    exit 1
  fi
}

is_unsupported_backend_sync_error() {
  local backend="$1"
  local output="$2"

  [[ "$backend" == "bd" ]] || return 1
  [[ "$output" == *"unknown command \"sync\""* || "$output" == *"unknown command 'sync'"* ]]
}

# ── Help / Version ───────────────────────────────────────────────────────────

show_help() {
  local backend
  backend=$(detect_backend)
  cat <<EOF
tm - Abstract Task Manager CLI (v${TM_VERSION})

Usage: tm <command> [args...]

Routes all commands to the configured backend.
Currently configured backend: ${backend}

Backend detection (highest priority first):
  1. TM_BACKEND environment variable
  2. tm.backend in .beads/config.yaml
  3. Default: bd

Available backends:
$(tm_backend_help_lines)

Examples:
  tm ready              Show tasks ready to work on
  tm show <id>          Show task details
  tm update <id> --status in_progress
                        Update task status through the selected backend
  tm close <id>         Close a task

Supported commands and behavior can vary by backend.
EOF
}

show_version() {
  local backend
  backend=$(detect_backend)
  echo "tm ${TM_VERSION} (backend: ${backend})"
}

# ── Main ─────────────────────────────────────────────────────────────────────

main() {
  # Handle tm-specific flags before routing
  if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
    show_help
    exit 0
  fi

  if [[ "${1:-}" == "--version" || "${1:-}" == "-v" ]]; then
    show_version
    exit 0
  fi

  local backend
  backend=$(detect_backend)
  validate_backend "$backend"

  local ORIGINAL_PWD="$PWD"

  case "$backend" in
    bd|br|tk)
      local backend_cmd
      backend_cmd="$backend"
      if ! command -v "$backend_cmd" >/dev/null 2>&1; then
        if [[ "$backend_cmd" == "bd" ]]; then
          echo "tm: bd not found in PATH. Install beads first: https://github.com/Dicklesworthstone/beads_viewer" >&2
        elif [[ "$backend_cmd" == "br" ]]; then
          echo "tm: br not found in PATH. Install beads_rust first: https://github.com/Dicklesworthstone/beads_rust" >&2
        else
          echo "tm: tk not found in PATH. Install Ticket first or select a different tm.backend." >&2
        fi
        exit 1
      fi
      local repo_root
      repo_root="$(find_repo_root)"
      if [[ -n "$repo_root" ]]; then
        cd "$repo_root"
      fi

      local args=("$@")
      # br create uses --description instead of --design
      if tm_backend_should_translate_create_design "$backend" && [[ "${1:-}" == "create" ]]; then
        local new_args=()
        local i=0
        while [[ $i -lt ${#args[@]} ]]; do
          local arg="${args[$i]}"
          if [[ "$arg" == "--design" ]]; then
            new_args+=("--description")
          elif [[ "$arg" == "--design-file" ]]; then
            local next_idx=$((i + 1))
            if [[ $next_idx -lt ${#args[@]} ]]; then
              local design_file="${args[$next_idx]}"
              # Resolve design_file relative to ORIGINAL_PWD if it is not absolute
              local resolved_design_file="$design_file"
              if [[ "$design_file" != /* ]]; then
                resolved_design_file="$ORIGINAL_PWD/$design_file"
              fi
              if [[ -f "$resolved_design_file" ]]; then
                new_args+=("--description" "$(cat "$resolved_design_file")")
                i=$next_idx
              else
                echo "tm: design file '$design_file' not found (resolved to '$resolved_design_file')" >&2
                exit 1
              fi
            else
              echo "tm: --design-file requires a file path" >&2
              exit 1
            fi
          else
            new_args+=("$arg")
          fi
          i=$((i + 1))
        done
        args=("${new_args[@]}")
      fi

      # Intercept sync: run backend-local sync first, then supported follow-on sync.
      if [[ "${1:-}" == "sync" ]]; then
        if [[ "${2:-}" == "--help" || "${2:-}" == "-h" || "${2:-}" == "--version" || "${2:-}" == "-v" ]]; then
          exec "$backend_cmd" "${args[@]}"
        fi
        local sync_exit=0
        local sync_stderr_file
        local sync_stderr
        sync_stderr_file="${TMPDIR:-/tmp}/tm-sync-stderr-$$-${RANDOM:-0}"
        if [[ "$(tm_backend_sync_mode "$backend_cmd")" == "flush-only" ]]; then
          local sync_args=("${@:2}")
          local has_flush_only=0
          local sync_arg
          for sync_arg in "${sync_args[@]}"; do
            if [[ "$sync_arg" == "--flush-only" ]]; then
              has_flush_only=1
              break
            fi
          done
          if [[ "$has_flush_only" -eq 1 ]]; then
            "$backend_cmd" sync "${sync_args[@]}" 2>"$sync_stderr_file" || sync_exit=$?
          else
            "$backend_cmd" sync --flush-only "${sync_args[@]}" 2>"$sync_stderr_file" || sync_exit=$?
          fi
        else
          "$backend_cmd" sync "${@:2}" 2>"$sync_stderr_file" || sync_exit=$?
        fi
        sync_stderr="$(<"$sync_stderr_file")"
        if command -v rm >/dev/null 2>&1; then
          rm -f "$sync_stderr_file"
        fi

        if [[ "$sync_exit" -ne 0 ]] && is_unsupported_backend_sync_error "$backend_cmd" "$sync_stderr"; then
          echo "tm: ${backend_cmd} backend does not support sync; local sync skipped" >&2
          sync_exit=0
        elif [[ -n "$sync_stderr" ]]; then
          printf '%s\n' "$sync_stderr" >&2
        fi

        # Only run follow-on sync if local sync succeeded or was unsupported and skipped.
        if [[ "$sync_exit" -ne 0 ]]; then
          echo "tm: ${backend_cmd} sync failed (exit $sync_exit), skipping follow-on sync" >&2
          exit "$sync_exit"
        fi

        if ! tm_backend_supports_follow_on_linear_sync "$backend_cmd"; then
          if linear_sync_configured "$backend_cmd"; then
            echo "tm: follow-on Linear sync is not supported for backend '$backend_cmd'; local sync completed and follow-on sync was skipped" >&2
          fi
          exit 0
        fi

        if ! command -v node >/dev/null 2>&1; then
          if linear_sync_configured "$backend_cmd"; then
            echo "tm: Linear sync is configured but Node.js is unavailable." >&2
            exit 1
          fi
          exit 0
        fi
        if [[ ! -f "$TM_SCRIPT_DIR/tm-linear-sync.js" ]]; then
          if linear_sync_configured "$backend_cmd"; then
            echo "tm: Linear sync is configured but tm-linear-sync.js is missing." >&2
            exit 1
          fi
          exit 0
        fi
        local linear_exit=0
        TM_REPO_ROOT="${repo_root:-$PWD}" node "$TM_SCRIPT_DIR/tm-linear-sync.js" || linear_exit=$?
        if [[ "$linear_exit" -ne 0 ]]; then
          echo "tm: Linear sync failed with exit code $linear_exit" >&2
        fi
        exit "$linear_exit"
      fi
      exec "$backend_cmd" "${args[@]}"
      ;;
    linear)
      local repo_root
      repo_root="$(find_repo_root)"
      if [[ -n "$repo_root" ]]; then
        cd "$repo_root"
      fi
      if ! command -v node >/dev/null 2>&1; then
        echo "tm: Linear backend requires Node.js." >&2
        exit 1
      fi
      if [[ ! -f "$TM_SCRIPT_DIR/tm-linear-backend.js" ]]; then
        echo "tm: tm-linear-backend.js is missing." >&2
        exit 1
      fi
      exec env TM_REPO_ROOT="${repo_root:-$PWD}" node "$TM_SCRIPT_DIR/tm-linear-backend.js" "$@"
      ;;
  esac
}

main "$@"
