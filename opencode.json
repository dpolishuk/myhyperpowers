{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "ralph",
  "plugin": [],
  "mcp": {
    "perplexity-mcp": {
      "type": "local",
      "command": [
        "perplexity-mcp",
        "--model",
        "sonar-pro",
        "--reasoning-model",
        "sonar-reasoning-pro"
      ],
      "environment": {
        "PERPLEXITY_API_KEY": "{env:PERPLEXITY_API_KEY}"
      }
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      }
    },
    "serena": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--transport",
        "stdio",
        "--project",
        ".",
        "--context",
        "ide-assistant"
      ]
    }
  },
  "permission": {
    "todowrite": "allow",
    "todoread": "allow",
    "skill": "allow",
    "webfetch": "allow",
    "question": "allow",
    "read": "allow",
    "edit": "allow",
    "write": "allow",
    "grep": "allow",
    "glob": "allow",
    "list": "allow",
    "lsp": "allow",
    "patch": "allow"
  },
  "model": "glm/glm-4.7",
  "small_model": "glm/glm-4.5",
  "agent": {
    "ralph": { "model": "glm/glm-4.7" },
    "test-runner": { "model": "glm/glm-4.5" },
    "codebase-investigator": { "model": "glm/glm-4.5" },
    "internet-researcher": { "model": "glm/glm-4.5" },
    "code-reviewer": { "model": "glm/glm-4.7" },
    "review-quality": { "model": "glm/glm-4.7" },
    "review-implementation": { "model": "glm/glm-4.7" },
    "review-testing": { "model": "glm/glm-4.7" },
    "review-simplification": { "model": "glm/glm-4.7" },
    "review-documentation": { "model": "glm/glm-4.7" },
    "test-effectiveness-analyst": { "model": "glm/glm-4.7" },
    "autonomous-reviewer": { "model": "glm/glm-4.7" }
  }
}
