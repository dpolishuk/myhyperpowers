{
  "$schema": "https://opencode.ai/config.json",
  "enabled": true,
  "blockStopIfUncommitted": false,
  "autoCommitOnSessionEnd": false,
  "autoCommitMessage": "wip: session changes",
  "showDiffOnWarning": true,
  "maxFilesInToast": 5,
  "protectedPaths": [
    ".env",
    ".env.*",
    "**/.git/hooks/*",
    "id_rsa",
    "*.pem",
    "*.key"
  ],
  "logDir": ".opencode/cache/git-guard",
  "warnOnIdle": true,
  "warnOnStop": true
}
